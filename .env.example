# ===== Vercel/배포 환경 변수 가이드 =====
# 실제 값은 .env (gitignore됨) 에 작성하거나 Vercel 대시보드 "Environment Variables" 에 등록하세요.

# Google Gemini API 키 (https://aistudio.google.com/app/apikey 에서 발급)
GOOGLE_AI_API_KEY="YOUR_GEMINI_API_KEY"

# (선택) Gemini 모델 오버라이드. 기본은 gemini-3-flash-preview
# GEMINI_MODEL="gemini-3-flash-preview"

# PostgreSQL 접속 정보 (호환성 유지용 — Prisma는 아래 DATABASE_URL만 사용)
DB_HOST=your-postgres-host
DB_USER=postgres
DB_PASS=your-password
DB_NAME=postgres
DB_PORT=5432

# Prisma용 DB URL — diet 스키마 사용
# 형식: postgresql://USER:PASS@HOST:PORT/DBNAME?schema=diet
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:5432/postgres?schema=diet"

# JWT 서명 비밀키 (32자 이상 권장 — 프로덕션은 반드시 강력한 랜덤 값)
# 생성 예: openssl rand -base64 48
AUTH_SECRET="REPLACE_WITH_node_-e_console.log(require('crypto').randomBytes(48).toString('base64'))_RESULT"
